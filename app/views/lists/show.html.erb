<div class="text-center mt-5 mb-5">
<h1 class="mb-5 mt-5 text-center rounded-4"> Liste des films du genre : <%= @list.name %> </h1>
<%= link_to "Ajouter un nouveau film dans cette liste", new_list_movie_path(@list), class: "btn btn-outline-primary" %>
<%= link_to "Retourner à la liste des genres de film", lists_path, class: "btn btn-outline-danger text-decoration-none rounded-pill"%>
</div>

<div class="d-flex justify-content-evenly">
  <% @movies.each do |movie|%>
    <div class="card" style="width: 18rem;">
      <img src="<%= movie.poster_url %>" class="card-img-top" alt="...">
      <div class="card-body">
        <ul class="list-group list-group-flush">
          <li class="list-group-item"><strong>Titre :</strong> <%= movie.title %></li>
          <li class="list-group-item"><strong>Description :</strong> <%= movie.overview %></li>
          <li class="list-group-item"><strong>Note :</strong> <%= movie.rating %>⭐</li>
          <li class="list-group-item">
          <%= link_to "Supprimer", list_movie_path(@list, movie), data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr?" }, class: "btn btn-outline-danger" %>
          </li>
        </ul>
      </div>
    </div>
  <% end %>
</div>

<%= link_to "Supprimer cette liste de ce genre", list_path, data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr?" }, class: "btn btn-outline-danger text-decoration-none rounded-pill"%>
